#!/usr/bin/env bash
set -e

BASE_DIR="/opt/nioxon"
CONFIG_DIR="$BASE_DIR/config"
PROVISION_DIR="$BASE_DIR/provision"
RUNTIME_ENV="$CONFIG_DIR/runtime.env"
STATE_FILE="$CONFIG_DIR/state.log"
LOG_FILE="$CONFIG_DIR/provision.log"

# Ensure config directory exists & writable
mkdir -p "$CONFIG_DIR"
chmod 755 "$CONFIG_DIR"


# ---------------- UI ----------------
green(){ echo -e "\033[32m$1\033[0m"; }
red(){ echo -e "\033[31m$1\033[0m"; }
yellow(){ echo -e "\033[33m$1\033[0m"; }
bold(){ echo -e "\033[1m$1\033[0m"; }

spinner() {
  local pid=$1
  local spin='-\|/'
  while kill -0 "$pid" 2>/dev/null; do
    for i in {0..3}; do
      printf "\r  %s " "${spin:$i:1}"
      sleep 0.1
    done
  done
  printf "\r"
}

# ---------------- RESUME / RETRY ----------------
mark_done() {
  grep -qx "$1" "$STATE_FILE" 2>/dev/null || echo "$1" >> "$STATE_FILE"
}

is_done() {
  grep -qx "$1" "$STATE_FILE" 2>/dev/null
}

reset_state() {
  rm -f "$STATE_FILE"
}

# ---------------- Helpers ----------------
detect_lan() {
  if command -v nmcli >/dev/null 2>&1; then
    local dev
    dev=$(nmcli -t -f DEVICE,TYPE device | awk -F: '$2=="ethernet"{print $1; exit}')
    if [ -n "$dev" ]; then
      echo "$dev"
      return 0
    fi
  fi

  # Fallback: scan /sys/class/net/ for interfaces starting with 'e' (ethernet)
  for dev in /sys/class/net/e*; do
    if [ -d "$dev" ]; then
      basename "$dev"
      return 0
    fi
  done

  # Second fallback: scan /sys/class/net/ and ignore 'lo' and wireless 'w'
  for dev in /sys/class/net/*; do
    if [ -d "$dev" ]; then
      local name
      name=$(basename "$dev")
      if [ "$name" != "lo" ] && [[ "$name" != w* ]]; then
        echo "$name"
        return 0
      fi
    fi
  done
  
  echo ""
}

detect_wifi() {
  if command -v nmcli >/dev/null 2>&1; then
    local dev
    dev=$(nmcli -t -f DEVICE,TYPE device | awk -F: '$2=="wifi"{print $1; exit}')
    if [ -n "$dev" ]; then
      echo "$dev"
      return 0
    fi
  fi

  # Fallback: scan /sys/class/net/ for interfaces starting with 'w'
  for dev in /sys/class/net/w*; do
    if [ -d "$dev" ]; then
      basename "$dev"
      return 0
    fi
  done
  
  echo ""
}

require_internet() {
  curl -fsSL https://google.com >/dev/null || {
    red "❌ Internet not available"
    exit 1
  }
}

parse_pat_file() {
  local fpath="$1"
  local val=""
  while IFS= read -r line || [ -n "$line" ]; do
    # Trim whitespace and CR
    line=$(echo "$line" | tr -d '\r' | sed -e 's/^[ \t]*//' -e 's/[ \t]*$//')
    [ -z "$line" ] && continue
    [[ "$line" == "#"* ]] && continue
    
    # Normalize spaces around '='
    local line_norm
    line_norm=$(echo "$line" | sed 's/[ \t]*=[ \t]*/=/g')
    
    # Convert to uppercase for comparison of the key part
    local upper_line_norm
    upper_line_norm=$(echo "$line_norm" | tr '[:lower:]' '[:upper:]')
    
    if [[ "$upper_line_norm" == *"PAT="* ]]; then
      # Extract the value from the original normalized line to preserve case
      val="${line_norm#*=}"
      val=$(echo "$val" | sed -e 's/^[ \t"'\'']*//' -e 's/[ \t"'\'']*$//')
      break
    elif [ -z "$val" ]; then
      # Store the first non-comment non-empty line as fallback
      val=$(echo "$line" | sed -e 's/^[ \t"'\'']*//' -e 's/[ \t"'\'']*$//')
    fi
  done < "$fpath"
  echo "$val"
}

detect_usb_pat() {
  local search_dirs=("/media" "/mnt")
  local file_names=("github.pat" "github_pat.txt" "pat.txt" "nioxon_pat.txt")

  echo "🔍 Scanning already mounted directories..." >&2
  # 1. Check already mounted directories (Desktop automount or manual mount)
  for base in "${search_dirs[@]}"; do
    if [ -d "$base" ]; then
      for fname in "${file_names[@]}"; do
        local found_file
        found_file=$(find "$base" -maxdepth 3 -name "$fname" -type f 2>/dev/null | head -n 1)
        if [ -n "$found_file" ] && [ -f "$found_file" ]; then
          echo "  - Found PAT file in mounted directory: $found_file" >&2
          local val
          val=$(parse_pat_file "$found_file")
          if [ -n "$val" ]; then
            echo "$val"
            return 0
          fi
        fi
      done
    fi
  done

  echo "🔍 Scanning block devices for USB drives..." >&2
  # 2. If not found, try to auto-detect and mount any plugged-in USB drive (Headless Server)
  local temp_mount="/tmp/nioxon_usb_mount"
  local usb_devs=()
  
  local usb_parts=()
  local usb_disks=()
  
  if [ -d "/sys/class/block" ]; then
    for dev_path in /sys/class/block/*; do
      if [ -e "$dev_path" ]; then
        local dev_name
        dev_name=$(basename "$dev_path")
        if [ -b "/dev/$dev_name" ]; then
          local sys_path
          sys_path=$(readlink -f "$dev_path" 2>/dev/null || true)
          if [[ "$sys_path" == */usb* ]]; then
            if [ -f "$dev_path/partition" ]; then
              usb_parts+=("/dev/$dev_name")
            else
              # Exclude loop, ram, etc. just in case
              if [[ "$dev_name" =~ ^(sd[a-z]|nvme[0-9]n[0-9]|mmcblk[0-9])$ ]]; then
                usb_disks+=("/dev/$dev_name")
              fi
            fi
          fi
        fi
      fi
    done
  fi

  # Combine: try partitions first, then whole disks
  usb_devs=("${usb_parts[@]}" "${usb_disks[@]}")

  # Fallback to /dev/disk/by-id/usb-* if usb_devs is still empty
  if [ ${#usb_devs[@]} -eq 0 ] && [ -d "/dev/disk/by-id" ]; then
    for link in /dev/disk/by-id/usb-*; do
      if [ -L "$link" ]; then
        local real_dev
        real_dev=$(readlink -f "$link")
        if [[ ! " ${usb_devs[*]} " =~ " ${real_dev} " ]]; then
          usb_devs+=("$real_dev")
        fi
      fi
    done
  fi

  # Fallback to general /dev/sd* (including sda) if still empty
  if [ ${#usb_devs[@]} -eq 0 ]; then
    for dev in /dev/sd[a-z][0-9] /dev/sd[a-z]; do
      if [ -b "$dev" ]; then
        usb_devs+=("$dev")
      fi
    done
  fi

  if [ ${#usb_devs[@]} -eq 0 ]; then
    echo "  ❌ No USB block devices detected" >&2
    rmdir "$temp_mount" >/dev/null 2>&1 || true
    return 1
  fi

  # Detect root disk to avoid scanning/mounting the host system drive
  local root_partition
  root_partition=$(findmnt -no SOURCE / 2>/dev/null || grep -w "/" /proc/mounts | awk '{print $1}' | head -n 1 || true)
  local root_disk=""
  if [ -n "$root_partition" ]; then
    root_disk=$(echo "$root_partition" | sed -E 's/p?[0-9]+$//')
    echo "  - Identified root OS disk: $root_disk (excluding from search)" >&2
  fi

  for dev in "${usb_devs[@]}"; do
    if [ -b "$dev" ]; then
      # Exclude root OS disk and its partitions
      if [ -n "$root_disk" ] && [[ "$dev" == "$root_disk"* ]]; then
        continue
      fi
      
      echo "  - Evaluating block device: $dev" >&2
      # Check if already mounted
      local mnt_point
      mnt_point=$(findmnt -no TARGET "$dev" 2>/dev/null || grep -w "$dev" /proc/mounts | awk '{print $2}' | head -n 1 || true)
      
      if [ -n "$mnt_point" ] && [ -d "$mnt_point" ]; then
        echo "    - Device $dev is already mounted at $mnt_point. Scanning..." >&2
        for fname in "${file_names[@]}"; do
          local fpath
          fpath=$(find "$mnt_point" -maxdepth 3 -name "$fname" -type f 2>/dev/null | head -n 1)
          if [ -n "$fpath" ] && [ -f "$fpath" ]; then
            echo "      - Found PAT file: $fpath" >&2
            local val
            val=$(parse_pat_file "$fpath")
            if [ -n "$val" ]; then
              echo "$val"
              return 0
            fi
          fi
        done
      else
        echo "    - Device $dev is not mounted. Attempting to mount temporarily..." >&2
        mkdir -p "$temp_mount"
        local mount_err
        mount_err=$(mount -o ro "$dev" "$temp_mount" 2>&1)
        local mount_status=$?
        
        # Try without -o ro if read-only mount failed (some filesystems/drivers prefer default mount)
        if [ $mount_status -ne 0 ]; then
          mount_err=$(mount "$dev" "$temp_mount" 2>&1)
          mount_status=$?
        fi
        
        if [ $mount_status -eq 0 ]; then
          echo "      - Successfully mounted $dev" >&2
          for fname in "${file_names[@]}"; do
            local fpath="$temp_mount/$fname"
            if [ -f "$fpath" ]; then
              echo "      - Found PAT file on mounted USB: $fpath" >&2
              local val
              val=$(parse_pat_file "$fpath")
              if [ -n "$val" ]; then
                umount "$temp_mount" >/dev/null 2>&1 || umount -l "$temp_mount" >/dev/null 2>&1
                rmdir "$temp_mount" >/dev/null 2>&1 || true
                echo "$val"
                return 0
              fi
            fi
          done
          umount "$temp_mount" >/dev/null 2>&1 || umount -l "$temp_mount" >/dev/null 2>&1
        else
          echo "      ❌ Failed to mount $dev: $mount_err" >&2
        fi
      fi
    fi
  done

  rmdir "$temp_mount" >/dev/null 2>&1 || true
  echo "  ❌ PAT file not found on any USB drives" >&2
  return 1
}

# ---------------- Step Runner (WITH RESUME) ----------------
run_step() {
  local step="$1"
  local label="$2"

  if is_done "$step"; then
    yellow "• $label (skipped)"
    return
  fi

  printf "• %-30s" "$label"
  echo -e "\n=== Running Step: $step ($label) at $(date) ===" >> "$LOG_FILE"
  bash "$PROVISION_DIR/$step.sh" >> "$LOG_FILE" 2>&1 &
  spinner $!
  wait $! && {
    green "✔ Done"
    mark_done "$step"
  } || {
    red "✖ Failed ($step)"
    echo "----------------------------------------"
    echo "Last 15 lines of log ($LOG_FILE):"
    tail -n 15 "$LOG_FILE"
    echo "----------------------------------------"
    echo "Review the full log at: $LOG_FILE"
    exit 1
  }
}

# ---------------- Commands ----------------
configure() {
  bold "⚙️ NIOXON Configuration"

  LAN_IFACE=$(detect_lan)
  LAN_IFACE=${LAN_IFACE:-eth0}
  WIFI_IFACE=$(detect_wifi)

  read -p "Use default configuration values? (y/n) [y]: " USE_DEFAULTS
  USE_DEFAULTS=${USE_DEFAULTS:-y}

  if [[ "$USE_DEFAULTS" =~ ^[Yy] ]]; then
    PROJECT_NAME="nioxon"
    SITE_DOMAIN="nioxplay.lan"
    LAN_IP="192.168.1.2"
    LAN_NETMASK="24"
    ENABLE_DHCP="true"
    APP_SOURCE_TYPE="git"
    API_SOURCE_VALUE="https://github.com/nioxon/nioxplay-app-ott-api"
    FRONTEND_SOURCE_VALUE="https://github.com/nioxon/niox-play"
    
    GITHUB_PAT=$(detect_usb_pat || true)
    if [ -n "$GITHUB_PAT" ]; then
      green "🔑 GitHub PAT successfully loaded from USB drive"
    else
      read -sp "GitHub Personal Access Token (for private repos, hidden): " GITHUB_PAT
      echo ""
    fi
  else
    read -p "Project name [nioxon]: " PROJECT_NAME
    PROJECT_NAME=${PROJECT_NAME:-nioxon}

    read -p "Domain [nioxplay.lan]: " SITE_DOMAIN
    SITE_DOMAIN=${SITE_DOMAIN:-nioxplay.lan}

    read -p "LAN interface [$LAN_IFACE]: " IN_LAN
    LAN_IFACE=${IN_LAN:-$LAN_IFACE}

    read -p "LAN IP [192.168.1.2]: " LAN_IP
    LAN_IP=${LAN_IP:-192.168.1.2}

    read -p "LAN subnet [24]: " LAN_NETMASK
    LAN_NETMASK=${LAN_NETMASK:-24}

    read -p "Enable local DHCP server? (y/n) [y]: " IN_DHCP
    IN_DHCP=${IN_DHCP:-y}
    if [[ "$IN_DHCP" =~ ^[Yy] ]]; then
      ENABLE_DHCP="true"
    else
      ENABLE_DHCP="false"
    fi

    read -p "App deployment source (usb/git/local) [usb]: " APP_SOURCE_TYPE
    APP_SOURCE_TYPE=${APP_SOURCE_TYPE:-usb}

    GITHUB_PAT=""
    if [ "$APP_SOURCE_TYPE" = "git" ]; then
      read -p "API Git Repository URL [https://github.com/nioxon/nioxplay-app-ott-api]: " API_SOURCE_VALUE
      API_SOURCE_VALUE=${API_SOURCE_VALUE:-https://github.com/nioxon/nioxplay-app-ott-api}

      read -p "Frontend Git Repository URL [https://github.com/nioxon/niox-play]: " FRONTEND_SOURCE_VALUE
      FRONTEND_SOURCE_VALUE=${FRONTEND_SOURCE_VALUE:-https://github.com/nioxon/niox-play}

      GITHUB_PAT=$(detect_usb_pat || true)
      if [ -n "$GITHUB_PAT" ]; then
        green "🔑 GitHub PAT successfully loaded from USB drive"
      else
        read -sp "GitHub Personal Access Token (for private repos, hidden): " GITHUB_PAT
        echo ""
      fi
    elif [ "$APP_SOURCE_TYPE" = "local" ]; then
      read -p "Local API Directory Path: " API_SOURCE_VALUE
      read -p "Local Frontend Directory Path: " FRONTEND_SOURCE_VALUE
    else
      # USB Mode Defaults
      API_SOURCE_VALUE="nioxplay-app-ott-api"
      FRONTEND_SOURCE_VALUE="niox-play"
    fi
  fi

  cat > "$RUNTIME_ENV" <<EOF
PROJECT_NAME=$PROJECT_NAME
SITE_DOMAIN=$SITE_DOMAIN
LAN_IFACE=$LAN_IFACE
LAN_IP=$LAN_IP
LAN_NETMASK=$LAN_NETMASK
WIFI_IFACE=$WIFI_IFACE
ENABLE_DHCP=$ENABLE_DHCP
APP_SOURCE_TYPE=$APP_SOURCE_TYPE
API_SOURCE_VALUE=$API_SOURCE_VALUE
FRONTEND_SOURCE_VALUE=$FRONTEND_SOURCE_VALUE
GITHUB_PAT=$GITHUB_PAT
EOF

  green "✔ Configuration saved"
}

install() {
  bold "🚀 NIOXON Provisioning"

  [ ! -f "$RUNTIME_ENV" ] && {
    red "Run: nioxon configure"
    exit 1
  }

  source "$RUNTIME_ENV"
  require_internet

  bold "🔵 Phase 1 — System"
  run_step "00-system" "System update"
  run_step "01-security" "Security"
  run_step "02-network-manager" "NetworkManager"
  run_step "03-nginx" "Nginx"
  run_step "04-php" "PHP"
  run_step "05-mysql" "MySQL"
  run_step "06-node" "Node.js"
  run_step "07-redis" "Redis"
  run_step "08-supervisor" "Supervisor"
  bold "⚠ Phase 2 — Captive Network"
  run_step "10-lan" "LAN Netplan"
  run_step "11-dns" "Captive DNS"
  run_step "12-redirect" "HTTP Redirect"
  run_step "13-ott-api" "OTT API Setup (Laravel)"
  run_step "14-niox-play" "Niox Play Setup (Frontend)"
  run_step "15-monitoring" "API health monitoring"

  green "🎉 Done → http://$SITE_DOMAIN"
}

setup() {
  local force=false
  if [ "$1" = "--force" ] || [ "$1" = "-f" ]; then
    force=true
  fi

  if [ "$force" = "true" ]; then
    reset_state
    rm -f "$LOG_FILE"
  fi

  configure
  install
}

# ---------------- Router ----------------
case "$1" in
  setup) setup "$2" ;;
  configure) configure ;;
  install) install ;;
  *)
    echo "NIOXON CLI"
    echo "  nioxon setup [--force|-f]  - Configure and install (resumes unless --force)"
    echo "  nioxon configure           - Configure settings only"
    echo "  nioxon install             - Install components (resumes automatically)"
    ;;
esac
